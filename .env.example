# Production environment for the Rails app. Copy to `.env`, fill in real values,
# and wire it into however you run the container. Never commit the real .env —
# /.env* is gitignored.

# Postgres connection for app + Solid cache/queue/cable (see config/database.yml).
DATABASE_URL=

# Verbatim contents of config/master.key (decrypts credentials in production).
RAILS_MASTER_KEY=

# The admin account, seeded on first boot by db:prepare (db/seeds.rb). Accounts
# are optional, but this gives you one to log in with.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Public host — used for mailer link URLs (share links follow the request host).
APP_HOST=playquartets.com

# --- Outbound mail (forgot-password) ----------------------------------------
# Preferred: Resend's HTTP API over port 443. Set RESEND_API_KEY (the re_... key)
# and MAILER_SENDER; the app uses the :resend delivery method automatically. Leave
# blank to disable mail (the app boots fine; reset emails just won't send).
MAILER_SENDER=no-reply@playquartets.com
RESEND_API_KEY=

# SMTP fallback — only used if RESEND_API_KEY is blank.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain

# --- Error monitoring (Sentry) — optional -----------------------------------
# Paste the project DSN from sentry.io to turn on production error reporting.
# Blank = off (the app runs fine without it). PII is never sent — see
# config/initializers/sentry.rb.
SENTRY_DSN=
