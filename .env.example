# Production env for the Synology Compose project. Copy to `.env` *on the NAS*
# (in the project directory) and fill in real values. Never commit the real .env
# — /.env* is gitignored.

# A long random string. Generate one with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Verbatim contents of config/master.key (decrypts credentials in production).
RAILS_MASTER_KEY=

# The admin account, seeded on first boot by db:prepare (db/seeds.rb). Accounts
# are optional now, but this gives you one to log in with.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudflare Tunnel token (Zero Trust → Networks → Tunnels → create → copy token).
# Its public hostname routes playquartets.com → http://caddy:80 (the front proxy,
# which forwards to web:3000 — see Caddyfile).
TUNNEL_TOKEN=

# Only needed if the GHCR repo is PRIVATE — Watchtower auths with these to pull
# the image. A GitHub username + a PAT (classic) with read:packages. Leave blank
# for a public repo.
GITHUB_ACTOR=
GITHUB_TOKEN=

# Public host — used for mailer link URLs (share links follow the request host).
APP_HOST=playquartets.com

# Host port the web container is published on, for direct LAN access / debugging.
WEB_PORT=3000

# --- Outbound mail (forgot-password) — Resend HTTP API ----------------------
# Preferred: Resend's HTTP API over port 443 (SMTP ports are unreliable from the
# self-hosted NAS behind the ISP). Just set RESEND_API_KEY (the re_... key) and
# MAILER_SENDER; the app uses the :resend delivery method automatically. Leave it
# blank to disable mail (the app boots fine; reset emails just won't send).
MAILER_SENDER=no-reply@playquartets.com
RESEND_API_KEY=

# SMTP fallback — only used if RESEND_API_KEY is blank (e.g. a different host).
# Left here for reference; not needed when the API key is set.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain

# --- Error monitoring (Sentry) — optional -----------------------------------
# Paste the project DSN from sentry.io to turn on production error reporting.
# Blank = off (the app runs fine without it). PII is never sent — see
# config/initializers/sentry.rb. Setup runbook: docs/DEPLOY.md.
SENTRY_DSN=
