# Production env for the Synology Compose project. Copy to `.env` *on the NAS*
# (in the project directory) and fill in real values. Never commit the real .env
# — /.env* is gitignored.

# A long random string. Generate one with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Verbatim contents of config/master.key (decrypts credentials in production).
RAILS_MASTER_KEY=

# The admin account, seeded on first boot by db:prepare (db/seeds.rb). Accounts
# are optional now, but this gives you one to log in with.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudflare Tunnel token (Zero Trust → Networks → Tunnels → create → copy token).
# Its public hostname routes playquartets.com → http://caddy:80 (the front proxy,
# which forwards to web:3000 — see Caddyfile).
TUNNEL_TOKEN=

# Public host — used for mailer link URLs (share links follow the request host).
APP_HOST=playquartets.com

# Host port the web container is published on, for direct LAN access / debugging.
WEB_PORT=3000

# --- Outbound mail (forgot-password) — optional ----------------------------
# Leave blank until you wire up a transactional SMTP provider; the app boots and
# runs fine without it (reset emails just won't send). Then fill these + redeploy.
MAILER_SENDER=no-reply@playquartets.com
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
