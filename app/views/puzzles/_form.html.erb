<%= form_with model: puzzle, class: "m-form",
      data: {
        controller: "autosave",
        "autosave-debounce-value": 1000,
        action: "input->autosave#schedule change->autosave#schedule"
      } do |f| %>
  <p class="m-form__note">Your work saves automatically as you type — close the tab any time, it's safe.</p>
  <p class="m-form__autosave" data-autosave-target="status" aria-live="polite"></p>

  <% if puzzle.errors.any? %>
    <div class="m-form__errors is-wrong">
      <p><%= pluralize(puzzle.errors.count, "problem") %> stopped that from saving:</p>
      <ul>
        <% puzzle.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="m-form__field">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div class="m-form__field">
    <%= f.label :author_name, "Author" %>
    <%= f.text_field :author_name %>
  </div>

  <div class="m-form__field" data-controller="charcount"
       data-charcount-max-value="<%= Puzzle::DESCRIPTION_LIMIT %>">
    <%= f.label :description, "Short description" %>
    <%= f.text_area :description, rows: 2, maxlength: Puzzle::DESCRIPTION_LIMIT,
          data: { charcount_target: "input", action: "input->charcount#update" } %>
    <p class="m-form__note">Optional — shows when shared. <span data-charcount-target="count"></span></p>
  </div>

  <%# "Classic" is the default (general, NYT-grade). The YES toggle reveals a tag
      box for the niche it needs (a fandom, a single domain). CSS-only via :has. %>
  <fieldset class="m-form__field m-specialized">
    <legend class="m-specialized__q">Is this a themed Quartet? Do you have to be a super-nerd in your chosen theme to get it?</legend>

    <div class="m-specialized__row">
    <label class="m-toggle">
      <%= f.check_box :specialized, class: "m-toggle__box" %>
      <span class="m-toggle__yes">YES</span>
    </label>

    <div class="m-specialized__panel">
      <div class="m-tags" data-controller="tags" data-tags-suggest-url-value="<%= tags_path %>">
        <ul class="m-tags__chips" data-tags-target="chips">
          <% puzzle.tag_names.each do |name| %>
            <li class="m-tags__chip">
              <span><%= name %></span>
              <button type="button" class="m-tags__remove" data-action="tags#remove" aria-label="Remove <%= name %>">×</button>
              <input type="hidden" name="puzzle[tag_names][]" value="<%= name %>">
            </li>
          <% end %>
        </ul>
        <%# Always-present blank so clearing every tag actually clears them (the
            server drops the blank via Tag.for_name). %>
        <input type="hidden" name="puzzle[tag_names][]" value="">
        <input type="text" id="tag-input" class="m-tags__input" data-tags-target="input"
               data-action="input->tags#search focus->tags#search keydown->tags#keydown"
               placeholder="e.g. star wars" autocomplete="off"
               role="combobox" aria-expanded="false" aria-autocomplete="list">
        <ul class="m-tags__menu" data-tags-target="menu" role="listbox" hidden></ul>
      </div>
      <p class="m-specialized__hint">ok, add some tags about what kinda nerdery you need to know to do your dumb puzzle.</p>
    </div>
    </div>
  </fieldset>

  <%# Groups in swellgarfo order (blue → green → yellow → purple), and within
      each block: answers first, then the category — matching the form muscle
      memory the user already has. %>
  <%= f.fields_for :groups do |gf| %>
    <fieldset class="m-group m-group--<%= gf.object.color %>">
      <legend><%= gf.object.color.to_s.titleize %></legend>
      <%= gf.hidden_field :color %>
      <%= gf.hidden_field :position %>

      <div class="m-form__field">
        <label>Answers</label>
        <% Group::WORDS_PER_GROUP.times do |i| %>
          <%= text_field_tag "#{gf.object_name}[words][]",
                Array(gf.object.words)[i],
                placeholder: "Word #{i + 1}" %>
        <% end %>
      </div>

      <div class="m-form__field">
        <%= gf.label :description, "Category" %>
        <%= gf.text_field :description, placeholder: "What links them?" %>
      </div>
    </fieldset>
  <% end %>

  <div class="m-form__submit">
    <%# Plain save stays first so Enter does the safe thing (never an accidental
        publish). Once complete, it reads as the "keep it unlisted" choice. %>
    <%= f.button type: :submit, class: "m-btn" do %>
      <%= icon(:save) %><span data-autosave-target="submitLabel"><%= puzzle.complete? ? "Keep it unlisted (link only)" : "Save" %></span>
    <% end %>

    <%# Publish is the loud, encouraged path once the puzzle is complete — a second
        submit via formaction → the publish action — greyed and guarded with a
        tooltip until then. Saving instead keeps it unlisted (ADR-0008). %>
    <% if puzzle.persisted? && puzzle.unlisted? %>
      <span class="m-tooltip<%= ' is-blocked' unless puzzle.complete? %>"
            data-autosave-target="publishGuard">
        <%= tag.button type: :submit, formaction: publish_puzzle_path(puzzle),
              class: "m-btn m-btn--go#{' is-disabled' unless puzzle.complete?}",
              data: { autosave_target: "publish", action: "autosave#guardPublish" } do %>
          <%= icon(:eye) %><span>Publish to the site</span>
        <% end %>
        <span class="m-tooltip__bubble" role="tooltip">This puzzle is incomplete! Finish it before publishing.</span>
      </span>
    <% end %>
  </div>

  <% if puzzle.persisted? && puzzle.unlisted? %>
    <p class="m-form__note">Not ready to go public? Saving keeps it <strong>unlisted</strong> — anyone with the link can play, but it won't appear on the site or in search.</p>
  <% end %>
<% end %>
