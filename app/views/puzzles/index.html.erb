<% content_for :title, "Your puzzles" %>

<div class="l-container">
  <h1><%= multicolor("Your puzzles") %></h1>

  <% if !user_signed_in? && @puzzles_total > 0 %>
    <%= render "claim_cta", count: @puzzles_total %>
  <% end %>

  <div class="m-dashboard-actions">
    <%= link_to "+ New puzzle", new_puzzle_path, class: "m-btn m-btn--pop" %>
  </div>

  <% if @puzzles_total > 0 %>
    <ul class="m-puzzle-list m-puzzle-list--dash">
      <% @puzzles.each do |puzzle| %>
        <li class="m-puzzle-list__item">
          <% title = puzzle.title.presence || "Untitled draft" %>
          <div class="m-puzzle-list__head">
            <%= link_to multicolor(title),
                  (puzzle.published? ? play_path(puzzle.share_token) : edit_puzzle_path(puzzle)),
                  class: "m-puzzle-list__title" %>
            <span class="m-puzzle-list__status">
              <% if puzzle.published? %>
                Published &middot; <%= pluralize(puzzle.attempts.count, "play") %>
              <% else %>
                Draft
              <% end %>
            </span>
          </div>

          <%# One filled accent button per row (the encouraged next step), then
              quiet secondary links, then the danger group pushed to the right. %>
          <div class="m-puzzle-list__actions">
            <% if puzzle.published? %>
              <%= tag.button type: "button", class: "m-btn m-btn--sm",
                    data: { controller: "clipboard", clipboard_text_value: play_url(puzzle.share_token),
                            action: "clipboard#copy" } do %>
                <%= icon(:share) %><span data-clipboard-target="label">Share</span>
              <% end %>
              <%= link_to "Play", play_path(puzzle.share_token), class: "m-puzzle-list__link" %>
              <%= link_to "Stats", stats_puzzle_path(puzzle), class: "m-puzzle-list__link" %>
            <% elsif puzzle.complete? %>
              <%= button_to publish_puzzle_path(puzzle), method: :patch,
                    class: "m-btn m-btn--sm m-btn--go" do %>
                <%= icon(:eye) %><span>Publish</span>
              <% end %>
              <%= link_to "Edit", edit_puzzle_path(puzzle), class: "m-puzzle-list__link" %>
            <% else %>
              <%= link_to edit_puzzle_path(puzzle), class: "m-btn m-btn--sm" do %>
                <%= icon(:edit) %><span>Finish</span>
              <% end %>
            <% end %>

            <span class="m-puzzle-list__danger">
              <% if puzzle.published? %>
                <%= link_to "Unpublish?", unpublish_puzzle_path(puzzle), class: "m-puzzle-list__unpublish",
                      data: { turbo_method: :patch,
                              turbo_confirm: "Are you sure you want to unpublish #{title}?" } %>
              <% end %>
              <%= button_to "Delete", puzzle, method: :delete, class: "m-puzzle-list__delete",
                    data: { turbo_confirm: "Delete “#{title}”? This can’t be undone." } %>
            </span>
          </div>
        </li>
      <% end %>
    </ul>

    <% if @total_pages > 1 %>
      <nav class="m-pagination">
        <% if @page > 1 %>
          <%= link_to "← Prev", puzzles_path(page: @page - 1), class: "m-pagination__step" %>
        <% end %>
        <span class="m-pagination__at">Page <%= @page %> of <%= @total_pages %></span>
        <% if @page < @total_pages %>
          <%= link_to "Next →", puzzles_path(page: @page + 1), class: "m-pagination__step" %>
        <% end %>
      </nav>
    <% end %>
  <% else %>
    <p>No puzzles yet.</p>
    <%= link_to "Make your first one", new_puzzle_path, class: "m-btn m-btn--pop" %>
  <% end %>
</div>
