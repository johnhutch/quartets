<% content_for :title, "Your stuff" %>

<div class="l-container">
  <h1><%= multicolor("Your stuff") %></h1>

  <% if !user_signed_in? && @puzzles_total > 0 %>
    <%= render "claim_cta", count: @puzzles_total %>
  <% end %>

  <%= render "dashboard_stats", stats: @stats, author_stats: @author_stats %>

  <div class="m-dashboard-actions">
    <%= link_to "+ New quartet", new_puzzle_path, class: "m-btn m-btn--pop" %>
  </div>

  <% if @puzzles_total > 0 %>
    <ul class="m-puzzle-list m-puzzle-list--dash">
      <%= render partial: "row", collection: @puzzles, as: :puzzle %>
    </ul>

    <% if @total_pages > 1 %>
      <nav class="m-pagination">
        <% if @page > 1 %>
          <%= link_to "← Prev", puzzles_path(page: @page - 1), class: "m-pagination__step" %>
        <% end %>
        <span class="m-pagination__at">Page <%= @page %> of <%= @total_pages %></span>
        <% if @page < @total_pages %>
          <%= link_to "Next →", puzzles_path(page: @page + 1), class: "m-pagination__step" %>
        <% end %>
      </nav>
    <% end %>
  <% else %>
    <div class="m-empty-stack">
      <p class="m-empty">No puzzles yet — this page is yours to fill.</p>
      <%= link_to "Make one #{ne_arrow}", new_puzzle_path, class: "m-stamp" %>
    </div>
  <% end %>
</div>
