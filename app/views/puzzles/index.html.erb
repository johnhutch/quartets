<% content_for :title, "Your puzzles" %>

<div class="l-container">
  <h1><%= multicolor("Your puzzles") %></h1>

  <% if !user_signed_in? && @puzzles.any? %>
    <%= render "claim_cta", count: @puzzles.size %>
  <% end %>

  <%= button_to "+ New puzzle", puzzles_path, method: :post, class: "m-btn m-btn--pop" %>

  <% if @puzzles.any? %>
    <ul class="m-puzzle-list">
      <% @puzzles.each do |puzzle| %>
        <li>
          <%= link_to(puzzle.title.presence || "Untitled draft", edit_puzzle_path(puzzle)) %>
          <% if puzzle.draft? %>
            <span class="is-draft">draft</span>
          <% else %>
            <%= link_to "Play", play_path(puzzle.share_token), class: "m-puzzle-list__play" %>
            <%= link_to "Stats", stats_puzzle_path(puzzle), class: "m-puzzle-list__stats" %>
            <%= link_to "Export", export_puzzle_path(puzzle) %>
          <% end %>
          <%= button_to "Delete", puzzle, method: :delete, class: "m-btn",
                data: { turbo_confirm: "Delete this puzzle?" } %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>No puzzles yet.</p>
    <%= button_to "Make your first one", puzzles_path, method: :post, class: "m-btn m-btn--pop" %>
  <% end %>
</div>
