<% content_for :title, "Quartets" %>

<div class="l-container">
  <header class="m-hero-brutal">
    <div class="m-hero-brutal__top">
      <%= link_to "Create #{ne_arrow}", new_puzzle_path, class: "m-sticker m-create-sticker" %>
    </div>
    <div class="m-nameplate-stack">
      <h1 class="m-wordmark"><%= multicolor("Quartets") %></h1>
      <span class="m-nameplate" aria-hidden="true">NoTimes</span>
    </div>
    <p class="m-lede">16 words. 4 hidden groups.
    Find the threads before you run out of guesses.</p>
  </header>

  <% if @puzzle %>
    <p class="m-hero__nowplaying">Today's pick: <strong><%= @puzzle.title %></strong></p>

    <%= render "play/board", puzzle: @puzzle %>

    <nav class="m-home-nav">
      <%= link_to "Play another →", root_path, class: "m-btn" %>
      <%= link_to "Browse all", play_index_path, class: "m-btn m-btn--pop" %>
    </nav>
  <% elsif @cleared_them_all %>
    <div class="m-empty">
      <p class="m-home__cleared">You've done them all.</p>
      <p>Go touch grass, loser.</o>
      <p>Or, y'know, go <%= link_to "make a new one #{ne_arrow}", new_puzzle_path, class: "m-stamp" %></p>
    </div>
  <% else %>
    <div class="m-empty">
      <p>No puzzles yet — the board's empty for now.</p>
      <p><%= link_to "Browse all", play_index_path %> · <%= link_to "Sign in", new_user_session_path %> to create one.</p>
    </div>
  <% end %>

  <footer class="m-home-foot"><%= link_to "Sign in", new_user_session_path %></footer>
</div>
