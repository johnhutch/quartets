<% content_for :title, "Sign up" %>

<div class="l-container m-auth">
  <h1><%= multicolor("Sign up") %></h1>
  <p class="m-auth__lede">An account keeps every puzzle you make in one place — across devices — and unlocks their stats.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
        html: { class: "m-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="m-form__field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            inputmode: "email", placeholder: "you@example.com" %>
    </div>

    <div class="m-form__field">
      <%= f.label :password %>
      <%= f.password_field :password, autocomplete: "new-password",
            placeholder: @minimum_password_length ? "#{@minimum_password_length}+ characters" : "Choose a password" %>
    </div>

    <div class="m-form__field">
      <%= f.label :password_confirmation, "Confirm password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            placeholder: "••••••••" %>
    </div>

    <%= f.submit "Sign up", class: "m-btn m-btn--pop" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
