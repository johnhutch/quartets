<% content_for :title, "Change your password" %>

<div class="l-container m-auth">
  <h1><%= multicolor("New password") %></h1>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name),
        html: { method: :put, class: "m-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div class="m-form__field">
      <%= f.label :password, "New password" %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
            placeholder: @minimum_password_length ? "#{@minimum_password_length}+ characters" : "New password" %>
    </div>

    <div class="m-form__field">
      <%= f.label :password_confirmation, "Confirm new password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            placeholder: "••••••••" %>
    </div>

    <%= f.submit "Change my password", class: "m-btn m-btn--pop" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
