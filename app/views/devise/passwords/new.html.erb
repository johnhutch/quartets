<% content_for :title, "Forgot your password?" %>

<div class="l-container m-auth">
  <h1><%= multicolor("Forgot password") %></h1>
  <p class="m-auth__lede">Drop your email and we'll send a reset link.</p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name),
        html: { method: :post, class: "m-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="m-form__field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            inputmode: "email", placeholder: "you@example.com" %>
    </div>

    <%= f.submit "Send reset instructions", class: "m-btn m-btn--pop" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
