<%# Difficulty meter: four segments filling easiest→hardest with an "x/4
    difficulty" readout (RatingSummary#difficulty_level, 1–4). Renders nothing
    when unrated. Expects `summary`. %>
<% if summary&.difficulty_level %>
  <span class="m-difficulty" title="<%= summary.difficulty_label %>">
    <span class="m-difficulty__meter" aria-hidden="true">
      <% (1..4).each do |i| %>
        <span class="m-difficulty__seg<%= ' is-on' if i <= summary.difficulty_level %>"></span>
      <% end %>
    </span>
    <span class="m-difficulty__label"><%= summary.difficulty_level %>/4 difficulty</span>
  </span>
<% end %>
