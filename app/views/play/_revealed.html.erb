<%# The owner's view of their own complete puzzle: the board in its finished
    state, every group revealed. Owners don't play their own puzzles (they know
    the answers — no self-earned trophies or stats), so this is a look, not a
    game. Same solved-row markup the live game and the revisit view render.
    Expects a `puzzle` local. %>
<div class="m-result" data-owner-view="true">
  <div class="m-game__solved">
    <% puzzle.groups.each do |group| %>
      <div class="m-group m-group--<%= group.color %> m-game__group">
        <strong class="m-game__group-name"><%= group.description %></strong>
        <span class="m-game__group-words"><%= group.filled_words.join(", ") %></span>
      </div>
    <% end %>
  </div>

  <%# You can't play it, but you can still push it on people. %>
  <div class="m-game__share">
    <%= tag.button type: "button", class: "m-btn m-btn--share",
          data: { controller: "share", share_url_value: play_url(puzzle.share_token),
                  action: "share#share" } do %>
      <%= icon(:share) %><span data-share-target="label">Share</span>
    <% end %>
  </div>
</div>
