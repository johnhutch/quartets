<%# The playable board. Shared by the homepage and /p/:share_token so they stay
    identical. We feed the game controller the groups (color + category + the
    four words) as JSON; it shuffles the 16 tiles, runs the guess loop, and caps
    mistakes at MAX_MISTAKES. Expects a `puzzle` local; an optional `saved`
    PlayState rehydrates a half-played board (guess log + play clock) so coming
    back resumes instead of resetting. %>
<% saved = local_assigns[:saved] %>
<%= tag.div class: "m-game",
      data: {
        controller: "game",
        game_max_mistakes_value: Puzzle::MAX_MISTAKES,
        game_record_url_value: play_attempts_path(puzzle.share_token),
        game_events_url_value: play_events_path(puzzle.share_token),
        game_progress_url_value: play_progress_path(puzzle.share_token),
        game_saved_value: (saved ? { guesses: saved.guesses, elapsedMs: saved.elapsed_ms } : {}).to_json,
        game_puzzle_value: {
          groups: puzzle.groups.map { |g|
            { color: g.color, description: g.description, words: g.filled_words }
          }
        }.to_json
      } do %>
  <%# Wrong-guess feedback floats over the title/byline area (positioned absolute,
      above the board) so it never reserves a row. %>
  <span class="m-game__toast" data-game-target="toast" aria-live="polite"></span>

  <div class="m-game__solved" data-game-target="solved"></div>

  <%# The win/lose stamp overlays the board (centered) — no reserved row. %>
  <div class="m-board-wrap">
    <div class="m-board" data-game-target="board"></div>
    <p class="m-game__status" data-game-target="status" aria-live="polite"></p>
  </div>

  <p class="m-game__mistakes">
    <span class="m-game__mistakes-label">Mistakes remaining</span>
    <span class="m-game__mistakes-boxes" data-game-target="mistakes" aria-live="polite"></span>
  </p>

  <div class="m-game__controls">
    <button type="button" class="m-btn" data-action="game#shuffle">Shuffle</button>
    <button type="button" class="m-btn" data-action="game#deselect">Deselect all</button>
    <button type="button" class="m-btn m-btn--primary"
            data-game-target="submit" data-action="game#submit" disabled>Submit</button>
  </div>
<% end %>
