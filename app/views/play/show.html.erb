<% content_for :title, @puzzle.title + " | Quartets"%>
<%# One description feeds SERP + social: the author's blurb if they wrote one,
    else a generated spoiler-free line (see puzzle_meta_description). The layout
    renders <meta name="description"> from content_for(:description); the :meta
    block carries the OG/Twitter tags (og:title needs the puzzle title). %>
<% desc = puzzle_meta_description(@puzzle) %>
<% content_for :description, desc %>
<%# The interactive board is the one page the game JS mutates in place (solved
    rows, win/lose stamp, is-over). Turbo would cache that finished snapshot and
    restore a broken hybrid board on the back button, so opt this render out of
    the cache. The server-rendered finished/owner states are static — fine to cache. %>
<% interactive_board = !@owned_view && !@my_attempt %>
<% content_for :meta do %>
  <% if interactive_board %>
    <meta name="turbo-cache-control" content="no-cache">
  <% end %>
  <%# Unlisted puzzles stay out of search, but keep the OG/Twitter tags so a
      shared link still unfurls a preview card (ADR-0008). %>
  <% unless @puzzle.published? %>
    <meta name="robots" content="noindex, nofollow">
  <% end %>
  <meta property="og:title" content="<%= @puzzle.title %> | Quartets">
  <meta name="twitter:title" content="<%= @puzzle.title %> | Quartets">
  <meta property="og:description" content="<%= desc %>">
  <meta name="twitter:description" content="<%= desc %>">
<% end %>

<div class="l-container">
  <% if owns?(@puzzle) && @puzzle.unlisted? %>
    <aside class="m-publish-prompt">
      <p class="m-publish-prompt__text">Looking good! Share the link with anyone, or publish it to the site.</p>
      <%= tag.button type: "button", class: "m-btn m-btn--share",
            data: { controller: "share", share_url_value: play_url(@puzzle.share_token),
                    action: "share#share" } do %>
        <%= icon(:share) %><span data-share-target="label">Share</span>
      <% end %>
      <%= button_to "Publish", publish_puzzle_path(@puzzle), method: :patch, class: "m-btn m-btn--pop" %>
    </aside>
  <% elsif @puzzle.published? && params[:published].present? %>
    <aside class="m-publish-prompt m-publish-prompt--done">
      <p class="m-publish-prompt__text">
        <%= multicolor(@puzzle.title) %> is published! Share it with your friends and enemies.
      </p>
      <%= tag.button type: "button", class: "m-btn m-btn--share",
            data: { controller: "share", share_url_value: play_url(@puzzle.share_token),
                    action: "share#share" } do %>
        <%= icon(:share) %><span data-share-target="label">Share</span>
      <% end %>
    </aside>
  <% end %>

  <%# Header: title + byline on the left, a compact meta-info box (votes + theme)
      floated to the right. The box only appears when there's something to show. %>
  <header class="m-play-header">
    <div class="m-play-header__main">
      <h1 class="m-play-title"><%= multicolor(@puzzle.title) %></h1>
      <% if @puzzle.author_display_name.present? %>
        <p class="m-byline">by <%= author_link(@puzzle) %></p>
      <% end %>
    </div>

    <% if @rating_summary || @puzzle.specialized? %>
      <aside class="m-metabox" aria-label="Quartet info">
        <% if @rating_summary %>
          <%= render "play/rating_summary", summary: @rating_summary %>
        <% end %>
        <% if @puzzle.specialized? %>
          <%= render "play/themed_flag", puzzle: @puzzle %>
        <% end %>
      </aside>
    <% end %>
  </header>

  <%# The author's blurb can telegraph the trick, so it hides behind a native
      <details> fold-out with a spoiler caption under the toggle. %>
  <% if @puzzle.description.present? %>
    <details class="m-description">
      <summary class="m-description__toggle">
        <span class="m-description__head">
          <span class="m-description__label">View description</span>
          <svg class="m-description__caret" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </span>
        <span class="m-description__warn">may contain hints or spoilers</span>
      </summary>
      <div class="m-description__body">
        <p class="m-description__text"><%= @puzzle.description %></p>
      </div>
    </details>
  <% end %>

  <% if @owned_view %>
    <%= render "play/revealed", puzzle: @puzzle %>
  <% elsif @my_attempt %>
    <%= render "play/result", puzzle: @puzzle, attempt: @my_attempt %>
  <% else %>
    <%= render "play/board", puzzle: @puzzle %>
  <% end %>

  <% unless owns?(@puzzle) %>
    <p class="m-play-back"><%= link_to "Play the Archive #{ne_arrow}", play_index_path, class: "m-sticker m-play-archive" %></p>
  <% end %>
</div>
