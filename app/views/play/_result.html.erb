<%# Shown when a non-owner revisits a puzzle they've already finished (ADR-0009,
    amended by ADR-0012 to include anonymous players). Reconstructs the game-over
    board from the recorded attempt — the groups revealed in the order they were
    cracked, then any unsolved ones — with the win/loss stamp, the emoji cube, and
    the trophies. Static: there's nothing to play, it's done. Expects `puzzle` and
    `attempt` locals. %>
<% cube = EmojiCube.new(attempt.guess_log).to_s %>
<% solved = attempt.solved_colors %>
<% by_color = puzzle.groups.index_by(&:color) %>
<% ordered = solved.filter_map { |color| by_color[color] } +
             puzzle.groups.reject { |group| solved.include?(group.color) } %>
<div class="m-result" data-played="true">
  <p class="m-game__status">
    <span class="m-stamp <%= attempt.solved? ? "m-stamp--win" : "m-stamp--lose" %>">
      <%= attempt.solved? ? "Solved it #{ne_arrow}" : "Out of guesses" %>
    </span>
  </p>

  <%# The board as it ended — same markup the live game renders at game over. %>
  <div class="m-game__solved">
    <% ordered.each do |group| %>
      <div class="m-group m-group--<%= group.color %> m-game__group">
        <strong class="m-game__group-name"><%= group.description %></strong>
        <span class="m-game__group-words"><%= group.filled_words.join(", ") %></span>
      </div>
    <% end %>
  </div>

  <%# Trophies + quip (ADR-0011); a logged-in trophy shows its running total. %>
  <% top = attempt.earned_tiers.last %>
  <%= render "play/achievement", attempt: attempt, signed_in: user_signed_in?,
        total: (current_user.attempts.at_least(top).count if user_signed_in? && top) %>

  <% if cube.present? %>
    <div class="m-game__share">
      <div class="m-cube"><%= cube %></div>
      <%= tag.button type: "button", class: "m-btn m-btn--share",
            data: { controller: "clipboard",
                    clipboard_text_value: ShareText.new(title: puzzle.title, cube: cube, url: play_url(puzzle.share_token)).to_s,
                    action: "clipboard#copy" } do %>
        <%= icon(:share) %><span data-clipboard-target="label">Copy result</span>
      <% end %>
    </div>
  <% end %>

  <p class="m-result__note">You've already played this one — here's how it went.</p>
</div>
