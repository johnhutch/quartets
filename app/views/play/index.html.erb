<% content_for :title, "Play" %>

<%# Archive filter, hoisted into the topbar (next to "Play More" on desktop, next
    to the wordmark on mobile). Only shown to a viewer who owns a published puzzle
    — everyone else has nothing to hide. Hidden+checkbox so an unchecked box still
    submits mine=show; on by default. %>
<% if @owns_published %>
  <% content_for :topbar_extra do %>
    <%= form_with url: play_index_path, method: :get, class: "l-topbar__filter", data: { controller: "autosubmit" } do %>
      <%= hidden_field_tag :mine, "show" %>
      <label class="l-topbar__filter-label">
        <%= check_box_tag :mine, "hide", @hide_mine, data: { action: "change->autosubmit#submit" } %>
        Hide my quartets
      </label>
    <% end %>
  <% end %>
<% end %>

<div class="l-container">
  <header class="m-play-head">
    <h1><%= multicolor("Play") %></h1>
    <%= link_to "Create #{ne_arrow}", new_puzzle_path, class: "m-sticker m-create-sticker" %>
  </header>

  <% if @puzzles.any? %>
    <ul class="m-puzzle-list">
      <% @puzzles.each do |puzzle| %>
        <li>
          <%= link_to puzzle.title, play_path(puzzle.share_token) %>
          <% if @completed_ids.include?(puzzle.id) %>
            <span class="m-puzzle-list__done">✓ Played</span>
          <% end %>
          <% if puzzle.author_name.present? %>
            <span class="m-puzzle-list__author">by <%= puzzle.author_name %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>No puzzles published yet. Check back soon.</p>
  <% end %>
</div>
