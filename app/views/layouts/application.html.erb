<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Quartets" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Quartets">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <meta property="og:site_name" content="Quartets">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    
    <%# Description is structural: every page emits one. A page sets its own via
        content_for(:description); otherwise the site default. Hoisted out of the
        :meta branch so coverage never depends on per-page discipline. %>
    <% page_description = content_for(:description).presence || ApplicationHelper::SITE_DESCRIPTION %>
    <meta name="description" content="<%= page_description %>">

    <% if content_for?(:meta) %>
      <%= yield :meta %>
    <% else %>
      <meta property="og:title" content="<%= content_for(:title) || "Quartets" %>">
      <meta name="twitter:title" content="<%= content_for(:title) || "Quartets" %>">
      <meta property="og:description" content="<%= page_description %>">
      <meta name="twitter:description" content="<%= page_description %>">
    <% end %>

    <meta property="og:url" content="<%= request.original_url %>">
    <link rel="canonical" href="<%= canonical_url %>">

    <%# Sitewide structured data — the entity every page shares. Per-page schema
        (a puzzle Game, the how-to-play FAQ) rides in content_for(:structured_data). %>
    <%= json_ld({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Quartets",
      url: root_url,
      description: ApplicationHelper::SITE_DESCRIPTION
    }) %>
    <%= yield :structured_data %>

    <%# Absolute image URL + dimensions so iMessage / Slack / Facebook all
        render the large card reliably. Versioned by FILENAME (og.png), not a
        ?v= query — iMessage's LinkPresentation is finicky about query strings on
        og:image, and some scrapers key their cache without the query. Bump the
        filename (og-2.png…) to bust caches on a future image change. %>
    <meta property="og:image" content="<%= root_url %>og.png">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Quartets">
    <meta name="twitter:image" content="<%= root_url %>og.png">

    <%# PWA manifest — installs the site as a standalone home-screen app. %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <meta name="apple-mobile-web-app-title" content="Quartets">
    <%# "black" (not black-translucent) so iOS reserves the status-bar area and keeps
        our content inside the safe area — otherwise the topbar sits under the clock/
        notch in standalone. Near-black status bar blends with the dark theme. %>
    <meta name="apple-mobile-web-app-status-bar-style" content="black">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Preload the display font (both weights) so it's ready before first paint —
        kills the font-swap reflow (CLS) on the wordmark + headings. %>
    <link rel="preload" href="<%= asset_path("space-grotesk-700.woff2") %>" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="<%= asset_path("space-grotesk-500.woff2") %>" as="font" type="font/woff2" crossorigin>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# Brutalist theme is the whole app now. A page can opt out by setting
      content_for(:body_class) to something else. %>
  <body class="<%= content_for?(:body_class) ? content_for(:body_class) : "theme-brutal" %>">
    <%# Bypass blocks (WCAG 2.4.1): the first focusable element jumps past the nav
        to <main>. Visually hidden until focused (see .l-skiplink). %>
    <a class="l-skiplink" href="#main">Skip to main content</a>
    <%# The homepage fronts its own nav (the split panel + floating auth); every
        other page gets the global topbar. %>
    <% unless home_page? %>
    <header class="l-topbar">
      <%= link_to multicolor("Quartets"), root_path, class: "l-topbar__home" %>

      <%# Desktop nav: inline, unchanged. Hidden below $bp-nav, where the hamburger
          below takes over (see _base.scss). %>
      <nav class="l-topbar__inline" aria-label="Primary">
        <%= link_to "Archive #{ne_arrow}", play_index_path, class: "l-topbar__btn" %>
        <span class="l-topbar__auth">
          <% if user_signed_in? %>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "l-topbar__btn" %>
            <% if current_user.staff? %>
              <%= link_to "Admin", admin_root_path, class: "l-topbar__btn" %>
            <% end %>
            <%= link_to "Your stuff", puzzles_path, class: "l-topbar__btn" %>
          <% else %>
            <%= link_to "Log in", new_user_session_path, class: "l-topbar__btn" %>
            <%= link_to "Sign up", new_user_registration_path, class: "l-topbar__btn" %>
          <% end %>
        </span>
      </nav>

      <%# Mobile nav: CSS-only hamburger (no JS). Closed <details> hides everything
          but the toggle; Turbo resets it closed on navigation. Create is the one
          tilted-yellow item; the rest are plain menu rows. %>
      <details class="l-nav">
        <summary class="l-nav__toggle" aria-label="Menu">
          <span class="l-nav__ico l-nav__ico--open"><%= icon(:menu) %></span>
          <span class="l-nav__ico l-nav__ico--close"><%= icon(:close) %></span>
        </summary>
        <nav class="l-nav__menu" aria-label="Menu">
          <% unless authoring_page? %>
            <%= link_to "Create #{ne_arrow}", new_puzzle_path, class: "m-sticker l-nav__create" %>
          <% end %>
          <%= link_to "Play More #{ne_arrow}", play_index_path, class: "l-nav__link" %>
          <% if user_signed_in? %>
            <%= link_to "Your stuff", puzzles_path, class: "l-nav__link" %>
            <% if current_user.staff? %>
              <%= link_to "Admin", admin_root_path, class: "l-nav__link" %>
            <% end %>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "l-nav__link" %>
          <% else %>
            <%= link_to "Log in", new_user_session_path, class: "l-nav__link" %>
            <%= link_to "Sign up", new_user_registration_path, class: "l-nav__link" %>
          <% end %>
        </nav>
      </details>
    </header>
    <% end %>

    <%# Status messages (WCAG 4.1.3): errors/alerts announce assertively, the
        rest politely. role + aria-live so a screen reader catches them on
        Turbo navigation without moving focus. %>
    <% flash.each do |type, message| %>
      <% assertive = type.to_s.in?(%w[alert error]) %>
      <div class="flash flash--<%= type %>"
           role="<%= assertive ? "alert" : "status" %>"
           aria-live="<%= assertive ? "assertive" : "polite" %>"><%= message %></div>
    <% end %>

    <main id="main">
      <%= yield %>
    </main>

    <%# The homepage rolls its own footer-as-section (creator + ethics + legal),
        so the global footer is suppressed there. %>
    <% unless home_page? %>
      <%= render "shared/footer" %>
    <% end %>
  </body>
</html>
